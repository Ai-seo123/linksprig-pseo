# PetalRank pSEO Engine Configuration

# Gemini API Key (Required for AI writer)
GEMINI_API_KEY=your_gemini_api_key_here

# WordPress REST API Settings (Optional, required for direct push to WordPress drafts/posts)
WP_URL=https://petalrank.com/
WP_USER=your_wordpress_username_here
WP_APP_PASSWORD=your_wordpress_application_password_here
WP_POST_STATUS=draft  # Set to 'draft' or 'publish'

# Target generation settings
DAILY_PAGES_GOAL=50
RUN_QA_VALIDATOR=True
EXPORT_MODE=csv  # Set to 'csv' or 'wp_api' or 'both'

# Path to the excel sheets for topic and keyword inputs (Optional)
EXCEL_PATH=C:\Users\ARNAV\Downloads\PetalRank-Blogs-Topics-Keywords.xlsx
HTML_IMPORT_PATH=C:\Users\ARNAV\Downloads\petalrank_blogs.html
